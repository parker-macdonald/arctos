# Copy to .env and fill in the values that apply to your environment.
# Every variable here is optional except SECRET_KEY; the app starts with
# sensible defaults for anything left blank. See docs/env-vars.md for
# the canonical reference, allowed values, and external setup notes.

# -- Required ----------------------------------------------------------------

# Random string used to sign Flask sessions. Generate one with:
#   python -c "import os; print(os.urandom(32).hex())"
# Format: any long random string.
SECRET_KEY=

# -- Public URLs -------------------------------------------------------------

# Public URL where this Arctos instance is reachable. Used for OAuth
# redirect URIs and any external-facing links the backend renders.
# Format: absolute URL, no trailing slash; e.g. https://arctos.example.org
EXTERNAL_BASE_URL=

# -- Dev-mode CORS -----------------------------------------------------------

# Set to 1 when running the Dioxus frontend on a different port from
# Flask (e.g. dx serve on :8080, gunicorn on :5006). Leave unset / 0 in
# production where nginx serves both same-origin.
# Format: 1 to enable; unset or 0 to disable.
ARCTOS_CORS_DEV=1

# -- Google sign-in (optional) ----------------------------------------------

# Format: values copied from Google Cloud Console OAuth credentials.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -- YouTube auto-seek and upload (optional) --------------------------------

# Format: API key / OAuth refresh token values from Google Cloud Console.
YOUTUBE_API_KEY=
YOUTUBE_UPLOAD_REFRESH_TOKEN=
# Format: numeric YouTube category id. 17 = Sports.
YOUTUBE_UPLOAD_CATEGORY_ID=17

# -- S3 video storage (optional; finalised videos stay on local disk otherwise)

# Format: bucket name only, not an s3:// URL.
S3_VIDEO_BUCKET=
# Format: absolute S3-compatible endpoint URL; e.g. https://s3.us-west-002.backblazeb2.com
S3_ENDPOINT_URL=
# Format: AWS/B2 region name; e.g. us-east-1 or us-west-002.
AWS_REGION=us-east-1
# Format: S3-compatible access key id and secret.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# -- Misc --------------------------------------------------------------------

# Format: true to show manual footage upload controls; false otherwise.
ENABLE_MANUAL_FOOTAGE_UPLOADS=false
# Format: delete or s3.
RECORDING_ARTIFACTS_AFTER_UPLOAD=delete
# Format: colon-separated account ids/usernames, e.g. alice:team-slug.
RETRY_FINALIZATION_USER_IDS=
# Format: colon-separated account ids/usernames.
SILLY_USERS=
